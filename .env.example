# 百度翻译（可选）
BAIDU_TRANSLATE_APP_ID=
BAIDU_TRANSLATE_SECRET=
TRANSLATE_API_URL=https://fanyi-api.baidu.com/api/trans/vip/translate
TRANSLATE_SOURCE_LANG=zh

# ========== Vercel / 外网部署（推荐）==========
# 仅需 DeepSeek 即可在全球访问站点使用阿楠文字聊天
DEEPSEEK_API_KEY=sk-your-key
DEEPSEEK_MODEL=deepseek-v4-flash

# 生产环境走服务端 API，不依赖本地 8787 代理（默认：未配置公网代理时自动开启）
# NEXT_PUBLIC_XIAOZHI_USE_SERVER_CHAT=true

# 可选：Vercel 服务端连小智云端（需先在 xiaozhi.me 绑定设备）
# XIAOZHI_WS_URL=wss://api.tenclass.net/xiaozhi/v1/
# XIAOZHI_DEVICE_TOKEN=test-token
# XIAOZHI_DEVICE_ID=24:0A:C4:xx:xx:xx
# XIAOZHI_CLIENT_ID=固定-uuid
# XIAOZHI_PROTOCOL_VERSION=3

# ========== 本地开发（语音 Opus）==========
# XIAOZHI_WS_URL=ws://127.0.0.1:8000/xiaozhi/v1/
# NEXT_PUBLIC_XIAOZHI_WS_PROXY_URL=ws://127.0.0.1:8787
# 然后: npm run xiaozhi:proxy && npm run dev

# 公网 WebSocket 代理（进阶：自有服务器部署 scripts/xiaozhi-ws-proxy.mjs 后填写）
# NEXT_PUBLIC_XIAOZHI_WS_PROXY_URL=wss://your-domain.com/xiaozhi-proxy

# MCP 接入点（扩展工具，与聊天无关）
# XIAOZHI_MCP_ENDPOINT=wss://api.xiaozhi.me/mcp/?token=...

# ========== 背景音乐 ==========
# 管理页 /admin/music 的访问密钥（必填，否则无法上传）
BGM_ADMIN_SECRET=your-strong-secret-here

# Vercel 部署时启用 Blob 存储（本地开发可留空，文件写入 public/music/）
# BLOB_READ_WRITE_TOKEN=vercel_blob_...
